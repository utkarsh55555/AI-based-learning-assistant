# ============================================================
# .env.example — Copy this to .env and fill in real values.
# Set ALL of these as Environment Variables in Vercel dashboard.
# ============================================================

# -- Supabase -----------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# -- OpenRouter AI ------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# -- Flask Security -----------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_flask_secret_key_min_32_chars
CSRF_SECRET_KEY=your_csrf_secret_key_min_32_chars
CSRF_TOKEN_EXPIRY_SECONDS=3600

# -- Environment --------------------------------------------
FLASK_ENV=production
FLASK_DEBUG=False
FORCE_HTTPS=True

# -- Rate Limiting ------------------------------------------
RATE_LIMIT_LOGIN=5 per minute
RATE_LIMIT_SIGNUP=3 per minute
RATE_LIMIT_API=120 per minute
# Use memory:// for serverless (Redis not persistent across function calls)
RATE_LIMIT_STORAGE_URI=memory://

# -- Account Lockout ----------------------------------------
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=900

# -- Field Encryption (optional) ----------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# -- JWT ----------------------------------------------------
JWT_EXPIRY_SECONDS=3600

# -- Audit Log ----------------------------------------------
AUDIT_LOG_FILE=audit.log

# -- CORS ---------------------------------------------------
# Set to your Vercel deployment URL (no trailing slash)
CORS_ORIGINS=https://your-app.vercel.app

# -- Frontend (Vite) ----------------------------------------
VITE_API_URL=https://your-app.vercel.app
