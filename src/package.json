{
  "name": "obsidian-ai-learning-companion",
  "version": "1.0.0",
  "description": "Comprehensive AI learning companion app with GPT integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "backend": "cd obsidian-backend-flask && python app.py",
    "start": "concurrently \"npm run backend\" \"npm run dev\" --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,cyan\"",
    "check-db": "cd obsidian-backend-flask && python check_tables.py"
  },
